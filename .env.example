# Listen port (default 8080)
PORT=8080

# Allowed browser `Origin` values (comma-separated, no trailing slash, no path).
# If unset, defaults include the public UI, localhost, and 127.0.0.1 on port 3000.
# Use the exact Origin the browser sends (https after TLS). Include http only if you still serve that.
# CORS_ORIGIN=https://maq.projektstudencki.pl,http://localhost:3000,http://127.0.0.1:3000

# --- SAML 2.0 Service Provider (PIONIER.id) — all required for SP routes to return 200/302 ---
# SAML_SP_ENTITY_ID=
# SAML_ACS_URL=
# SAML_ENTRY_POINT=
# SAML_IDP_CERT_PATH=
# SAML_SP_PUBLIC_CERT_PATH=
# SAML_SP_PRIVATE_KEY_PATH=
# SAML_SESSION_JWT_SECRET=
# SAML_LOGIN_SUCCESS_REDIRECT_URL=

# --- Opaque bearer tokens (auth_tokens — groups / drive `auth` field) ---
# Storage = hex(HMAC_SHA256(API_TOKEN_HMAC_SECRET, plaintext)); plaintext only from POST /api/login.
# API_TOKEN_HMAC_SECRET=
# Optional lifetime in seconds (defaults ~90 days if unset).
# API_TOKEN_TTL_SECONDS=7776000

# --- PostgreSQL (TypeORM; required for groups/drive APIs) ---
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=maq
# Set to true only for local/dev schema bootstrap — prefer migrations (`npm run typeorm:migration:run`) when TYPEORM_SYNC=false.
# TYPEORM_SYNC=false
# Run pending migrations on Nest bootstrap (optional; containers often use `typeorm:migration:run:dist` after build instead).
# TYPEORM_MIGRATIONS_RUN=false

# --- Drive file storage (multipart /drive) ---
# Absolute or cwd-relative root; final path: <DRIVE_STORAGE_ROOT>/drive/<organizationId>/<uuid>
# DRIVE_STORAGE_ROOT=./storage
# DRIVE_DEFAULT_ORGANIZATION_ID=1
# DRIVE_MAX_FILE_BYTES=15728640
