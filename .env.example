# Listen port (default 8080)
PORT=8080

# Allowed browser `Origin` values (comma-separated, no trailing slash, no path).
# If unset, defaults include the public UI, localhost, and 127.0.0.1 on port 3000.
# Use the exact Origin the browser sends (https after TLS). Include http only if you still serve that.
# CORS_ORIGIN=https://maq.projektstudencki.pl,http://localhost:3000,http://127.0.0.1:3000

# --- SAML 2.0 Service Provider — all required for SP routes to return 200/302 ---
# Direct UAM IdP: set SAML_ENTRY_POINT + SAML_IDP_CERT(_PATH) from UAM metadata
# (https://sso.amu.edu.pl/simplesaml/saml2/idp/metadata.php).
#
# Local Shibboleth proxy IdP (see ./infrastructure/saml-proxy-shibboleth/README.md):
# SAML_SP_ENTITY_ID=https://127.0.0.1:8080/api/auth/saml/metadata
# SAML_ACS_URL=http://127.0.0.1:8080/api/auth/saml/acs
# SAML_ENTRY_POINT=https://localhost:14443/idp/profile/SAML2/Redirect/SSO
# SAML_IDP_CERT_PATH=./infrastructure/saml-proxy-shibboleth/certs/proxy-idp-signing.pem
# SAML_SP_PUBLIC_CERT_PATH=./infrastructure/saml-proxy-shibboleth/certs/nest-sp-cert.pem
# SAML_SP_PRIVATE_KEY_PATH=./infrastructure/saml-proxy-shibboleth/certs/nest-sp-key.pem
# SAML_SESSION_JWT_SECRET=
# SAML_LOGIN_SUCCESS_REDIRECT_URL=
