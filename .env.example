# system-backend/.env — copy to `.env` (never commit `.env`).
# Used by Nest (`npm`) and `docker compose -f docker-compose.dev.yml`.
#
# Docker: `docker-compose.dev.yml` overrides SAML *_PATH to `/app/secrets/saml/…` in the container
# and sets CORS for the local SPA. Populate workspace `../secrets/saml/*.pem` (see `../secrets/README.md`).
# Local `npm`: use paths relative to `system-backend/` cwd — defaults point at `../secrets/saml/`.

PORT=8080

# Browser Origins (comma-separated, no trailing slash). Docker dev compose overrides for localhost UI.
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000,http://maq.projektstudencki.pl

# --- SAML: local Shibboleth proxy IdP (see ./infrastructure/saml-proxy-shibboleth/README.md) ---
SAML_SP_ENTITY_ID=https://127.0.0.1:8080/api/auth/saml/metadata
SAML_ACS_URL=http://127.0.0.1:8080/api/auth/saml/acs
SAML_ENTRY_POINT=https://localhost:14443/idp/profile/SAML2/Redirect/SSO
SAML_IDP_CERT_PATH=../secrets/saml/proxy-idp-signing.pem
SAML_SP_PUBLIC_CERT_PATH=../secrets/saml/nest-sp-cert.pem
SAML_SP_PRIVATE_KEY_PATH=../secrets/saml/nest-sp-key.pem
SAML_SESSION_JWT_SECRET=replace-with-a-long-random-secret-for-local-only
SAML_LOGIN_SUCCESS_REDIRECT_URL=http://127.0.0.1:3000/home
# never | ifPresent | always — use "never" locally (Shibboleth, npm --watch). Use ifPresent/always + shared cache in prod.
SAML_VALIDATE_IN_RESPONSE_TO=never
# NameIDPolicy Format (AuthnRequest). Default matches local Shibboleth metadata (transient). Set for your IdP if needed.
# SAML_IDENTIFIER_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress

# --- Optional: direct UAM IdP (metadata: https://sso.amu.edu.pl/simplesaml/saml2/idp/metadata.php) ---
# SAML_ENTRY_POINT=https://sso.amu.edu.pl/...
# SAML_IDP_CERT_PATH=...
# SAML_SP_ENTITY_ID=...
# SAML_ACS_URL=...

# --- Optional: multi-IdP institution picker — see GET /api/auth/saml/institutions ---
# SAML_UAM_ENTRY_POINT=https://sso.amu.edu.pl/simplesaml/saml2/idp/SSOService.php
# SAML_UAM_IDP_CERT_PATH=../secrets/saml/uam-idp-signing.pem
# SAML_LOCAL_PROXY_ENTRY_POINT=https://localhost:14443/idp/profile/SAML2/Redirect/SSO
# SAML_LOCAL_PROXY_IDP_CERT_PATH=../secrets/saml/proxy-idp-signing.pem
