# Listen port (default 8080)
PORT=8080

# Allowed browser `Origin` values (comma-separated, no trailing slash, no path).
# If unset, defaults include the public UI, localhost, and 127.0.0.1 on port 3000.
# Use the exact Origin the browser sends (https after TLS). Include http only if you still serve that.
# CORS_ORIGIN=https://maq.projektstudencki.pl,http://localhost:3000,http://127.0.0.1:3000

# --- SAML 2.0 Service Provider (PIONIER.id) — all required for SP routes to return 200/302 ---
# SAML_SP_ENTITY_ID=
# SAML_ACS_URL=
# SAML_ENTRY_POINT=
# SAML_IDP_CERT_PATH=
# SAML_SP_PUBLIC_CERT_PATH=
# SAML_SP_PRIVATE_KEY_PATH=
# SAML_SESSION_JWT_SECRET=
# SAML_LOGIN_SUCCESS_REDIRECT_URL=
# Required for GET /api/auth/saml/metadata (UAM default-sp XML shape; see docs/api.md)
# SAML_METADATA_TECH_CONTACT_GIVEN_NAME=
# SAML_METADATA_TECH_CONTACT_EMAIL=
# Use public URL of GET /api/auth/saml/logout, e.g. https://maq.projektstudencki.pl/api/auth/saml/logout
# SAML_METADATA_SLO_REDIRECT_URL=
# Optional: add HTTP-Artifact ACS row to GET /metadata (true|1|yes); default omit — ACS runtime is POST-only unless you add artifact SOAP resolution (docs/api.md)
# SAML_METADATA_INCLUDE_ARTIFACT_ACS=
# Optional: IdP SingleLogoutService URL (default UAM SimpleSAMLphp); override if your federation differs
# SAML_IDP_LOGOUT_URL=
