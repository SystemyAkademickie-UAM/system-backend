# Listen port (default 8080)
PORT=8080

# Allowed browser `Origin` values (comma-separated, no trailing slash, no path).
# If unset, defaults include the public UI, localhost, and 127.0.0.1 on port 3000.
# Use the exact Origin the browser sends (https after TLS). Include http only if you still serve that.
# CORS_ORIGIN=https://maq.projektstudencki.pl,http://localhost:3000,http://127.0.0.1:3000
